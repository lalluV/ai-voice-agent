# Application
APP_NAME=healeka-voice-agent
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=https://voice.example.com
PUBLIC_WS_BASE_URL=wss://voice.example.com
SHUTDOWN_GRACE_SECONDS=30

# Security
ADMIN_API_KEY=change-me-admin-key
# Set false only for local testing without Plivo signatures
PLIVO_VALIDATE_SIGNATURE=true

# Plivo
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_ANSWER_URL=
PLIVO_HANGUP_URL=

# Gemini (default; overridable per tenant)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE_NAME=Kore

# MongoDB (tenants + call logs)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=voice_agent

# Redis (optional DID cache)
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
TENANT_CACHE_TTL_SECONDS=300
DEPARTMENT_CACHE_TTL_SECONDS=600

# HMS defaults (per-tenant overrides in Mongo)
HMS_ORIGIN_HOST_PATTERN=https://{subdomain}.healeka.com
HMS_HTTP_TIMEOUT_SECONDS=10.0
HMS_HTTP_MAX_CONNECTIONS=100

# Audio
PLIVO_AUDIO_CONTENT_TYPE=audio/x-mulaw;rate=8000
PLIVO_SAMPLE_RATE=8000
GEMINI_INPUT_SAMPLE_RATE=16000
GEMINI_OUTPUT_SAMPLE_RATE=24000
